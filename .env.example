# ============================================================
# Environment Variables - Example Configuration
# Copy this file to .env in each service directory and update
# ============================================================

# =================
# Vehicle Maintenance Scheduler
# =================

# Server Configuration
PORT=3001
NODE_ENV=development

# API Configuration
EVALUATION_SERVICE_URL=http://4.224.186.213/evaluation-service
DEPOTS_ENDPOINT=http://4.224.186.213/evaluation-service/depots
VEHICLES_ENDPOINT=http://4.224.186.213/evaluation-service/vehicles

# Logging Configuration
LOG_LEVEL=info
ENABLE_DETAILED_LOGGING=true

# =================
# Notification App Backend
# =================

# Server Configuration
PORT=3002
NODE_ENV=development

# API Configuration
EVALUATION_SERVICE_URL=http://4.224.186.213/evaluation-service
NOTIFICATIONS_ENDPOINT=http://4.224.186.213/evaluation-service/notifications

# Logging Configuration
LOG_LEVEL=info
ENABLE_DETAILED_LOGGING=true

# =================
# Logging Middleware
# =================

# Logging Service Configuration
LOGGING_SERVICE_URL=http://4.224.186.213/evaluation-service/logs
LOG_ENABLED=true

# =================
# Common Configuration
# =================

# Node Environment
NODE_ENV=development  # or production

# API Timeouts
API_TIMEOUT_MS=30000

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# CORS Configuration (if needed)
CORS_ENABLED=false
CORS_ORIGIN=*

# Database (if used in future)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=campus_db
# DB_USER=dbuser
# DB_PASSWORD=dbpassword

# Redis (if used in future)
# REDIS_URL=redis://localhost:6379
# REDIS_TTL=300

# Authentication (if needed)
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=24h

# Service Discovery (if needed)
# SERVICE_REGISTRY_URL=http://service-registry:8080
# SERVICE_NAME=notification-service
# SERVICE_VERSION=1.0.0
